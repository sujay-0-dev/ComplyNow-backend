PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
JWT_SECRET=supersecret
MONGODB_URI=mongodb://root:password@localhost:27017/complynow
REDIS_URL=redis://localhost:6379

# ─── Requestly Integration ──────────────────────────────────────────────────

# Master toggle
REQUESTLY_ENABLED=true

# Proxy: route outbound HTTP through Requestly desktop app
REQUESTLY_PROXY_ENABLED=false
REQUESTLY_PROXY_HOST=localhost
REQUESTLY_PROXY_PORT=8888
REQUESTLY_PROXY_BYPASS=localhost,127.0.0.1,::1,internal.yourdomain.com
REQUESTLY_PROXY_SSL=true          # Trust Requestly's MITM cert (dev only)
REQUESTLY_CA_CERT_PATH=           # Path to Requestly root CA cert (optional)

# Mock endpoints (disable in production)
REQUESTLY_MOCK_ENABLED=true
REQUESTLY_MOCK_PREFIX=/requestly
REQUESTLY_MOCK_ENVS=development,test

# HAR traffic recording
REQUESTLY_HAR_ENABLED=true
REQUESTLY_HAR_MAX_ENTRIES=500
REQUESTLY_HAR_TTL=3600            # seconds to keep entries in Redis
REQUESTLY_HAR_REDACT_HEADERS=authorization,x-api-key,cookie,set-cookie
REQUESTLY_HAR_REDACT_FIELDS=password,token,card_number,cvv,secret

# Rules engine
REQUESTLY_RULES_PATH=./requestly-rules.json
REQUESTLY_RULES_HOT_RELOAD=true
REQUESTLY_WEBHOOK_SECRET=my_super_secret_webhook_key_1234  # Min 16 chars — required for webhook endpoint
