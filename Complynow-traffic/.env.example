# Service config
TRAFFIC_PORT=8001
TRAFFIC_HOST=0.0.0.0

# Public URL where this service is reachable
# Used in generated Requestly rules to point back here
# Change to production domain before deployment
PUBLIC_BASE_URL=http://localhost:8000

# Backend connection
# Traffic layer always forwards to backend — never directly to worker
BACKEND_URL=http://localhost:3000
BACKEND_AUDIT_ENDPOINT=/api/v1/audits/from-traffic
BACKEND_API_KEY=internal_service_key_here

# Session management
SESSION_TTL_SECONDS=300          # how long to hold open session
MAX_ENTRIES_PER_SESSION=500      # max HAR entries to collect
FLUSH_AFTER_ENTRIES=50           # auto-flush when batch reaches this size
FLUSH_AFTER_SECONDS=30           # auto-flush after this many seconds

# Rule file storage
RULES_DIR=public/rules
RULE_TTL_HOURS=24               # how long rule files are kept
